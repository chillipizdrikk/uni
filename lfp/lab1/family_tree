spouse(X,Y):- married(X,Y).
spouse(X,Y):- married(Y,X).

sister(X,Y) :- female(X), parent(Z,X), parent(Z,Y), X\=Y.
brother(X,Y):- male(X), parent(Z,X), parent(Z,Y), X\=Y.

uncle(X,Y):- male(X), parent(Z,Y), (brother(X,Z); (sister(M,Z), spouse(X,M))).
aunt(X,Y):- female(X), parent(Z,Y), (sister(X,Z); (brother(M,Z), spouse(X,M))).

grandmother(X,Y):- female(X), parent(X,Z), parent(Z,Y).
grandfather(X,Y):- male(X), parent(X,Z), parent(Z,Y).

great_grandmother(X,Y):- female(X), parent(X,Z), parent(Z,M), parent(M,Y).
great_grandfather(X,Y):- male(X), parent(X,Z), parent(Z,M), parent(M,Y).

cousin(X,Y):- parent(Z,X),parent(M,Y),(sister(Z,M);sister(M,Z);(brother(Z,M);brother(M,Z))).

ancestor(X,Y) :- parent(X,Y) ; (parent(X,Z), ancestor(Z,Y)).
descendant(X,Y) :- parent(Y,X) ; (parent(Z,X), descendant(Z,Y)).

